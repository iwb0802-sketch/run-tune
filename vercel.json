{
  "buildCommand": "cd packages/web && bunx vite build",
  "outputDirectory": "packages/web/dist",
  "installCommand": "bun install --frozen-lockfile",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/((?!api/.*).*)", "destination": "/index.html" }
  ]
}
